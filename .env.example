# ═══════════════════════════════════════════════════════════
# AURA Fashion AI — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file: cp .env.example .env
# Then fill in your API keys below.

# ── App ──────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=dev-secret-change-in-production

# ── Database ─────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./fashionai.db
REDIS_URL=redis://localhost:6379/0

# ── LLM (REQUIRED — get from console.groq.com) ──────────
GROQ_API_KEY=

# ── HuggingFace (REQUIRED — get from huggingface.co/settings/tokens) ──
HUGGINGFACE_API_KEY=

# ── Vector Search (OPTIONAL — uses BM25 fallback without)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── LLM Routing ─────────────────────────────────────────
LITELLM_PROXY_URL=http://localhost:4000
OLLAMA_BASE_URL=http://localhost:11434

# ── Observability (OPTIONAL — cloud.langfuse.com) ───────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Analytics (OPTIONAL — app.posthog.com) ──────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ── Push Notifications (OPTIONAL — console.firebase.google.com) ──
FIREBASE_SERVER_KEY=

# ── Storage ──────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
